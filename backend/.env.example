# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# See specs/005-supabase-data-layer/quickstart.md for setup instructions.

# Your Supabase project's REST URL. Found in:
#   Supabase Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Service-role JWT. SECRET. Bypasses RLS — never expose to the browser.
# Found in: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# The auth.users.id of the operator running this CLI. The service role writes
# on behalf of this user when --push-to-supabase is used.
# Found in: Supabase Dashboard → Authentication → Users → (your row) → id
SUPABASE_USER_ID=00000000-0000-0000-0000-000000000000
