# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# See specs/005-supabase-data-layer/quickstart.md for setup instructions.

# Your Supabase project's REST URL. Found in:
#   Supabase Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Service-role JWT. SECRET. Bypasses RLS — never expose to the browser.
# Found in: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# The auth.users.id of the operator running this CLI. The service role writes
# on behalf of this user when --push-to-supabase is used.
# Found in: Supabase Dashboard → Authentication → Users → (your row) → id
SUPABASE_USER_ID=00000000-0000-0000-0000-000000000000

# ---- Feature 006 (HTTP API) ----

# JWT secret used by the local Supabase (`supabase start`) for HS256 token
# minting in INTEGRATION TESTS ONLY. Production uses RS256/ES256 via JWKS;
# this is irrelevant outside tests. Find via: supabase status --output env
# SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# Optional: override CORS origins at runtime (comma-separated). Used by
# Feature 008's production deploy. Empty = use config.yaml defaults.
# CORS_ALLOW_ORIGINS=https://intraday-trade-spy.vercel.app

# Optional: regex for matching deployment-platform preview-branch domains
# (e.g., Vercel preview URLs).
# CORS_ALLOW_ORIGIN_REGEX=^https://intraday-trade-spy(-pr-\d+)?\.vercel\.app$
