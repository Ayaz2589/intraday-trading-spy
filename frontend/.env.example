# Copy to `.env.local` and fill in real values.
# `.env.local` is git-ignored; this template is committed.
# See specs/007-frontend-auth-api-migration/quickstart.md for setup.

# Supabase project URL (same as backend's SUPABASE_URL).
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase PUBLISHABLE key (sb_publishable_*). NEVER the service-role key.
# Service-role secrets live ONLY on the FastAPI server side.
VITE_SUPABASE_ANON_KEY=sb_publishable_XXXXX

# Feature 006 API base URL. Defaults to localhost:8001 in dev.
# Feature 008's deploy will set this to the production Fly.io URL.
VITE_API_BASE_URL=http://localhost:8001
